rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper ──────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── Matches ─────────────────────────────────────────────────────────────
    // Lecture publique (page d'accueil non connectée),
    // écriture réservée à l'admin.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    // Lecture autorisée à tous les connectés (classement).
    // Écriture : propriétaire du document OU admin.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Predictions ─────────────────────────────────────────────────────────
    // Lecture/écriture : propriétaire uniquement.
    // L'admin peut tout lire (recalcul des points côté serveur).
    match /predictions/{predictionId} {
      allow read: if request.auth != null
                  && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
